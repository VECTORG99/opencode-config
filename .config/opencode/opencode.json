{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    "__HOME__/.local/share/ponytail/.opencode/plugins/ponytail.mjs",
    "opencode-rules",
    "opencode-supermemory",
    "opencode-antigravity-auth",
    "opencode-agent-browser",
    "opencode-skill-creator",
    "opencode-nanobanana",
    "envsitter-guard",
    "cc-safety-net",
    "opencode-forge",
    "opencode-mem",
    "opencode-notify",
    "opencode-review-helper",
    "opencode-log-sanitizer",
    "oh-my-opencode-slim"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true
    },
    "semgrep": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "semgrep/mcp-server"
      ],
      "enabled": false
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres"
      ],
      "enabled": false
    }
  },
  "instructions": [
    "CLAUDE.md"
  ]
}
